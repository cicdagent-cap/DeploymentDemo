# Copy to .notification.local.env and fill in real values (never commit the local file).
# cp .env.example .notification.local.env

# Notifications
TEAM_WEBHOOK_URL=
CICD_CHAT_PROVIDER=teams

# Project defaults
CICD_PROJECT_FILE=DeploymentDemo.xcodeproj
CICD_DEFAULT_SCHEME=DeploymentDemo
CICD_DEFAULT_CONFIGURATION=Debug
CICD_TEST_DESTINATION="platform=iOS Simulator,name=iPhone 16"

# Fastlane / signing
FASTLANE_TEAM_ID=
FASTLANE_ITC_TEAM_ID=
FASTLANE_BUNDLE_IDENTIFIER=com.capgemini.DeploymentDemo
MATCH_GIT_URL=
MATCH_PASSWORD=
MATCH_GIT_BASIC_AUTHORIZATION=

# App Store Connect (required for release/TestFlight lanes)
APP_STORE_CONNECT_API_KEY=

# Firebase App Distribution (optional)
FIREBASE_APP_ID=
FIREBASE_CLI_TOKEN=
FIREBASE_GROUPS=testers
